dimCovers.push({top:top,left:left,width:width,height:height,opacity:0});
top+=height;
height=docHeight-top;
dimCovers.push({top:top,left:left,width:width,height:height});
left+=width
}top=bannerHeight;
width=docWidth-left;
height=docHeight-top;
dimCovers.push({top:top,left:left,width:width,height:height});
