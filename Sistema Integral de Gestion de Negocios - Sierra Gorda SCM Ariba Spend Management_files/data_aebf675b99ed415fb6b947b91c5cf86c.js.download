var wmContext;function WalkMeDataClass(){var P={publishDate:"2026-04-13 12:18:58",dataVersion:"0"},g={"BackButtonText":"Back","BalloonCloseTooltip":"Stop Walk-thru","BalloonSettings":{"AnimateFirst":true,"Animation":{"Id":3,"InitCSS":{"display":"block","margin":"-100px"},"MetaData":{"are":true},"Options":{"duration":800,"easing":"easeOutBounce"},"Properties":{"margin":0}},"AnimationId":null,"BalloonBorderWidth":1,"BalloonButtonRadius":8,"BalloonColor2":"#ffffff","BalloonRadius":8,"BalloonStyle":"california","BalloonVersion":"v3","BorderColor":"#ffffff","ButtonBgClickColor":"#1175E0","ButtonBgColor":"#1175E0","ButtonBgColor2":"#1f99b8","ButtonBgHoverColor":"#85BFFD","ButtonBorderColor":"#1175E0","ButtonShadowWidth":2,"ButtonTextColor":"#ffffff","Color":"#ffffff","ContentColor":"#586889","ContentPosition":0,"Font":"walkme-notosans, Arial","FontsData":[{"id":"poppins","name":"poppins","url":"/player/resources/fonts/poppins"},{"id":"proxima-nova","name":"proxima-nova","url":"/player/resources/fonts/proxima-nova"},{"id":"opensans","name":"opensans","url":"/player/resources/fonts/opensans"}],"FooterTextClickColor":"#ffffff","FooterTextColor":"#1175E0","FooterTextHoverColor":"#ffffff","HeaderColor":"#46587D","HighlighterColor":null,"HighlighterThickness":null,"SeparatorColor":"#ffffff","ShadowColor":"#1175E0","ShadowLevel":1,"ShadowType":1,"StepInfoColor":"#A2ABBD","ThemeId":38,"Vibrate":true,"XButtonClickColor":"#464646","XButtonColor":"#6B7997","XButtonHoverColor":"#46587D"},"BulletType":null,"ClosedMenuTitle":"Walk Me Through","ContentCloseTooltip":"Close","Custom":{"ThemeSelector":{"method":"Selector","value":"[aria-label=&#39;Theme&#39;] &gt; .w-pmi-item.w-pmi-check"},"appType":"native","aribaConfig":{"theme":{"selector":"[aria-label=&#39;Theme&#39;] &gt; .w-pmi-item.w-pmi-check"}},"capping":"3","insightsConfig":{"0":{"element":{"attributesToCollect":["src","href","type","name","role"],"censorshipRules":[],"inputValues":"remove"},"page":{"censorship":{},"disablePageChangeEvent":"true"},"recording":{"recordAll":"False"},"trafficBlocker":[]},"3":{"element":{"attributesToCollect":["src","href","type","name","role"],"censorshipRules":[],"inputValues":"remove"},"page":{"censorship":{},"disablePageChangeEvent":"true"},"recording":{"recordAll":"False"},"trafficBlocker":[]},"32":{"element":{"attributesToCollect":["src","href","type","name","role"],"censorshipRules":[],"inputValues":"remove"},"page":{"censorship":{},"disablePageChangeEvent":"true"},"recording":{"recordAll":"False"},"trafficBlocker":[]}},"powerMode":{"enabled":"True","numOfTaps":"5","pressTime":"5"},"proMenu":{"addBackground":"true","heightLimitSelector":"#commandBarTop","rtlVar":"walkmeLoaderConfig.rtl","zIndex":"1000"}},"CustomCss":"/* Custom Tooltip Styles UX.LG -- START */ \n\n.walkme-tooltip-outer-div, \n\n.walkme-tooltip-mid-div, \n\n.walkme-tooltip-inner-div { \n\n  border-radius: 8px !important; \n\n} \n\n.walkme-tooltip-mid-div { \n\n  box-shadow: 0px 4px 12px 0px rgba(34, 53, 72, 0.25) !important; \n\n} \n\n.walkme-tooltip-content { \n\n  padding: 16px !important; \n\n  font-size: var(--typography_body_font_size) !important; \n\n  line-height: 150% !important; \n\n} \n\n.walkme-tooltip-content, \n\n.walkme-tooltip-content * { \n\n  font-family: var(--fonts_primary_font) !important; \n\n} \n\n.walkme-tooltip-content a, \n\n.walkme-tooltip-content * a { \n\n  color: var(--colors_link_main) !important; \n\n} \n\n.walkme-tooltip-content a:hover, \n\n.walkme-tooltip-content * a:hover { \n\n  text-decoration: underline !important; \n\n} \n\n/* Custom Tooltip Styles UX.LG -- END */ \n\n \n\n \n\n/* Success Message Animation UX.LG -- START */ \n\n@keyframes success-message { \n\n  0% { \n\n    opacity: 0; \n\n    visibility: hidden; \n\n  } \n\n  1% { \n\n    opacity: 1; \n\n    visibility: visible; \n\n  } \n\n  100% { \n\n    opacity: 1; \n\n    visibility: visible; \n\n  } \n\n} \n\n/* Success Message Animation UX.LG -- END */ \n\n \n\n \n\n/* Animated Launchers UX.LG -- START */ \n\n.walkme-launcher-image-div[style*=&quot;HotSpot&quot;] { \n\n  background-color: var(--colors_primary_main); \n\nbackground-image: none !important; \n\n  border-radius: 24px; \n\n} \n\n.walkme-launcher-id-861536 .walkme-launcher-image-div[style*=&quot;HotSpot&quot;] { \n\nanimation-iteration-count: 2; \n\n} \n\n.walkme-launcher-id-861536:hover .walkme-launcher-image-div[style*=&quot;HotSpot&quot;] { \n\nanimation-iteration-count: infinite; \n\n} \n\n \n\n.walkme-launcher-image-div[style*=&quot;HotSpot&quot;]:before, \n\n.walkme-launcher-image-div[style*=&quot;HotSpot&quot;]:after{ \n\ncontent: &quot;&quot;; \n\nposition: absolute; \n\nheight: 100%; \n\nwidth: 100%; \n\nbackground-color: var(--colors_primary_main); \n\nborder-radius: 50%; \n\nz-index: -1; \n\nopacity: 0.7; \n\n} \n\n.walkme-launcher-image-div[style*=&quot;HotSpot&quot;]:before { \n\nanimation: wm-hotspot 2s ease-out 8; \n\n} \n\n.walkme-launcher-image-div[style*=&quot;HotSpot&quot;]:after { \n\nanimation: wm-hotspot 2s 1s ease-out 8; \n\n} \n\n.walkme-launcher-image-div[style*=&quot;HotSpot-Manual&quot;]:before, \n\n.walkme-launcher-image-div[style*=&quot;HotSpot-Manual&quot;]:after { \n\nanimation-iteration-count: 2; \n\n} \n\n.walkme-custom-launcher-outer-div:hover .walkme-launcher-image-div[style*=&quot;HotSpot-Manual&quot;]:before, \n\n.walkme-custom-launcher-outer-div:hover .walkme-launcher-image-div[style*=&quot;HotSpot-Manual&quot;]:after { \n\nanimation-iteration-count: infinite; \n\n} \n\n@keyframes wm-hotspot { \n\n100% { \n\ntransform: scale(2.5); \n\nopacity: 0; \n\n} \n\n} \n\n/* Animated Launchers UX.LG -- END */ \n\n \n\n \n\n/* Custom Survey Styles UX.LG -- START */ \n\n.walkme-survey-balloon { \n\n  width: 400px !important; \n\n  height: auto !important; \n\n  position: fixed !important; \n\n  top: 50% !important; \n\n  left: 50% !important; \n\n  transform: translate(-50%,-50%) !important; \n\n  margin: 0px !important; \n\n} \n\n.walkme-survey-balloon * { \n\n  font-family: var(--fonts_primary_font) !important; \n\n} \n\n.walkme-survey-balloon, \n\n.walkme-survey-balloon .walkme-custom-balloon-mid-div, \n\n.walkme-survey-balloon .walkme-custom-balloon-inner-div { \n\n  border-radius: 8px !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-mid-div { \n\n  box-shadow: 0px 20px 80px 0px rgba(34, 53, 72, 0.25) !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-inner-div { \n\n  background-color: var(--colors_background_main) !important; \n\n  border: none !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-top-div, \n\n.walkme-survey-balloon .walkme-custom-balloon-bottom-div { \n\n  background-color: transparent !important; \n\n} \n\n/* X */ \n\n.walkme-survey-balloon .walkme-custom-balloon-close-button { \n\n  width: 16px !important; \n\n  height: 16px !important; \n\n  margin: 16px !important; \n\n  text-align: center !important; \n\n  font-family: sans-serif !important; \n\n  font-size: 20px !important; \n\n  font-weight: 300 !important; \n\n  line-height: 72% !important; \n\n  color: var(--colors_text_main) !important; \n\n} \n\n/* Text */ \n\n.walkme-survey-balloon .walkme-custom-balloon-title { \n\n  display: none !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-content { \n\n  margin: 0px !important; \n\n  padding: 48px 16px 0px !important; \n\n  text-align: center !important; \n\n  font-size: var(--typography_body_font_size) !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-content a, \n\n.walkme-survey-balloon .walkme-custom-balloon-content * a { \n\n  text-decoration: underline !important; \n\n  color: var(--colors_link_main) !important; \n\n} \n\n/* Survey */ \n\n.walkme-survey-balloon .walkme-survey-questions { \n\n  padding: 0px !important; \n\n  overflow: visible !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question-title { \n\n  min-height: 40px !important; \n\n  margin: 0px !important; \n\n  padding: 0px 8px !important; \n\n  font-family: var(--fonts_primary_font) !important; \n\n  font-size: var(--typography_title_font_size) !important; \n\n  font-weight: var(--typography_title_font_weight) !important; \n\n  line-height: 115% !important; \n\n  color: var(--colors_text_main) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question-title .wm-smile { \n\n  display: inline-block !important; \n\n  position: absolute !important; \n\n  font-size: 0px !important; \n\n  visibility: hidden !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question-sub-title { \n\n  margin: 0px 0px 24px !important; \n\n  padding: 0px 8px !important; \n\n  font-family: var(--fonts_primary_font) !important; \n\n  font-size: var(--typography_body_font_size) !important; \n\n  line-height: 115% !important; \n\n  color: var(--colors_text_main) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question-sub-title .wm-label { \n\n  position: relative !important; \n\n  top: 20px !important; \n\n  left: -8px !miportant; \n\n  text-align: left !important; \n\n  font-size: 11px !important; \n\n  font-weight: 400 !important; \n\n  line-height: 14px !important; \n\n  color: var(--colors_info_main) !important; \n\n} \n\n/* Radiobuttons + Checkboxes */ \n\n.walkme-survey-balloon .walkme-survey-question-radiobutton-answers, \n\n.walkme-survey-balloon .walkme-survey-question-checkbox-answers { \n\n  display: flex !important; \n\n  flex-direction: row !important; \n\n  flex-wrap: wrap !important; \n\n  justify-content: center !important; \n\n  gap: 8px !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-radiobutton-answer, \n\n.walkme-survey-balloon .walkme-survey-question-checkbox-answer { \n\n  display: inline-block !important; \n\n  width: fit-content !important; \n\n  height: 26px !important; \n\n  margin: 0px !important; \n\n  padding: 0px 8px !important; \n\n  box-sizing: border-box !important; \n\n  background-color: var(--colors_background_main) !important; \n\n  border: 1px solid var(--colors_background_tint) !important; \n\n  border-radius: var(--buttons_secondary_default_border_radius) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-radiobutton-answer:hover, \n\n.walkme-survey-balloon .walkme-survey-question-checkbox-answer:hover { \n\n  background-color: var(--colors_custom_tint) !important; \n\n  border-color: var(--colors_background_tint) !important; \n\n  cursor: pointer !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-radiobutton-answer.selected, \n\n.walkme-survey-balloon .walkme-survey-question-checkbox-answer:has(.walkme-survey-answer-label-checked) { \n\n  background-color: var(--colors_custom_shade) !important; \n\n  border-color: var(--colors_secondary_shade) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question .walkme-survey-answer-radiobutton-div input { \n\n  display: none !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-answer-checkbox { \n\n  display: none !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-answer-text { \n\n  max-width: 100% !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-answer-text .walkme-survey-answer-title, \n\n.walkme-survey-balloon .walkme-survey-question-checkbox-answer .walkme-survey-answer-text { \n\n  vertical-align: top !important; \n\n  margin: 0px !important; \n\n  font-family: var(--fonts_primary_font) !important; \n\n  font-size: var(--typography_body_font_size) !important; \n\n  font-weight: 600 !important; \n\n  line-height: 24px !important; \n\n  white-space: nowrap !important; \n\n  color: var(--colors_secondary_main) !important; \n\n  -webkit-font-smoothing: antialiased !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-radiobutton-answer:hover .walkme-survey-answer-title, \n\n.walkme-survey-balloon .walkme-survey-question-checkbox-answer:hover .walkme-survey-answer-text { \n\n  color: var(--colors_secondary_tint) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-radiobutton-answer.selected .walkme-survey-answer-title, \n\n.walkme-survey-balloon .walkme-survey-question-checkbox-answer:has(.walkme-survey-answer-label-checked) .walkme-survey-answer-text { \n\n  color: var(--colors_secondary_shade) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-answer-text .walkme-survey-answer-subtitle:empty { \n\n  display: none !important; \n\n} \n\n/* Emoticon Question */ \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-question-radiobutton-answers { \n\n  display: block !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-radiobutton-answer { \n\n  width: 48px !important; \n\n  height: auto !important; \n\n  vertical-align: top !important; \n\n  margin: 0px 4px !important; \n\n  padding: 0px !important; \n\n  background-color: transparent !important; \n\n  border: none !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-radiobutton-answer .walkme-survey-answer-radiobutton-div { \n\n  width: 48px !important; \n\n  height: 48px !important; \n\n  box-sizing: border-box !important; \n\n  background-repeat: no-repeat !important; \n\n  background-size: 32px auto !important; \n\n  background-position: center !important; \n\n  border: 1px solid transparent !important; \n\n  border-radius: 8px !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-radiobutton-answer:hover .walkme-survey-answer-radiobutton-div { \n\n  background-color: var(--colors_custom_tint) !important; \n\n  border-color: var(--colors_info_tint) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-radiobutton-answer .walkme-survey-answer-radiobutton-div.selected { \n\n  background-color: var(--colors_custom_shade) !important; \n\n  border-color: var(--colors_primary_main) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-radiobutton-answer:hover .walkme-survey-answer-radiobutton-div.selected { \n\n  border-color: var(--colors_primary_main) !important; \n\n} \n\n/* Emoticon - 1 */ \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-question-radiobutton-answers div:first-child .walkme-survey-answer-radiobutton-div { \n\n  background-image: url(https://usercontent-us01.walkme.cloud.sap/1117178cd4e642328f294b27fe5dc19b/root___SAP_Face-Very-Unhappy-2.svg) !important; \n\n} \n\n/* Emoticon - 2 */ \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-question-radiobutton-answers div:nth-child(2) .walkme-survey-answer-radiobutton-div { \n\n  background-image: url(https://s3.walkmeusercontent.com/a31690ce84534542ae531525e9346ff0/root___SAP_Face-Unhappy-2.svg) !important; \n\n} \n\n/* Emoticon - 3 */ \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-question-radiobutton-answers div:nth-child(3) .walkme-survey-answer-radiobutton-div { \n\n  background-image: url(https://s3.walkmeusercontent.com/a31690ce84534542ae531525e9346ff0/root___SAP_Face-Neutral-2.svg) !important; \n\n} \n\n/* Emoticon - 4 */ \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-question-radiobutton-answers div:nth-child(4) .walkme-survey-answer-radiobutton-div { \n\n  background-image: url(https://s3.walkmeusercontent.com/a31690ce84534542ae531525e9346ff0/root___SAP_Face-Happy-2.svg) !important; \n\n} \n\n/* Emoticon - 5 */ \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-question-radiobutton-answers div:nth-child(5) .walkme-survey-answer-radiobutton-div { \n\n  background-image: url(https://s3.walkmeusercontent.com/a31690ce84534542ae531525e9346ff0/root___SAP_Face-Very-Happy-2.svg) !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-answer-text { \n\n  display: block !important; \n\n  height: fit-content !important; \n\n  margin-top: -4px !important; \n\n  text-align: center !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question:has(.wm-smile) .walkme-survey-answer-text .walkme-survey-answer-title { \n\n  height: auto !important; \n\n  text-align: center !important; \n\n  font-size: 10px !important; \n\nfont-weight: 400 !important; \n\n  line-height: 11.5px !important; \n\n  white-space: normal !important; \n\n  color: var(--colors_text_main) !important; \n\n} \n\n/* NPS */ \n\n.walkme-survey-balloon .walkme-survey-question-nps-answers { \n\n  text-align: center !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-answer-label-nps-radiobutton { \n\n  width: 40px !important; \n\n  height: 40px !important; \n\n  box-sizing: border-box !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question-nps-scores-wrapper { \n\n  margin: 8px 0px 0px !important; \n\n  text-align: left !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-question-nps-scores-wrapper div { \n\n  vertical-align: top !important; \n\n} \n\n/* Free Text */ \n\n.walkme-survey-balloon .walkme-survey-question-freetext-answers { \n\n  width: calc(100% - 16px) !important; \n\n  height: 54px !important; \n\n  margin: 0px 8px !important; \n\n  background-color: var(--colors_neutral_shade) !important; \n\n  border-radius: 4px !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-answer-textarea { \n\n  width: 100% !important; \n\n  height: 54px !important; \n\n  margin: 0px !important; \n\n  padding: 8px 10px !important; \n\n  box-sizing: border-box !important; \n\n  background-color: transparent !important; \n\n  box-shadow: none !important; \n\n  border: 1px solid var(--colors_text_main) !important; \n\n  border-radius: 4px !important; \n\n  font-family: var(--fonts_primary_font) !important; \n\n  font-size: 12px !important; \n\n  color: var(--colors_text_main) !important; \n\n  opacity: 0.5 !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-answer-textarea:hover { \n\n  opacity: 0.7 !important; \n\n} \n\n.walkme-survey-balloon .walkme-survey-answer-textarea:focus { \n\n  outline: none !important; \n\n  opacity: 1 !important; \n\n} \n\n/* Success Message */ \n\n.walkme-survey-balloon .walkme-survey-question-title .wm-success { \n\n  margin-bottom: 8px !important; \n\n} \n\n.walkme-survey-balloon:has(.wm-success) .walkme-survey-question-sub-title { \n\n  margin-top: 8px !important; \n\n} \n\n.walkme-survey-balloon:has(.wm-success) .walkme-custom-balloon-buttons-wrapper { \n\n  display: none !important; \n\n} \n\n.walkme-survey-balloon:has(.wm-success) .walkme-custom-balloon-bottom-div { \n\n  padding: 0px 0px 8px !important; \n\n} \n\n/* Footer */ \n\n.walkme-survey-balloon .walkme-custom-balloon-separator { \n\n  display: none !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-bottom-div { \n\n  padding: 24px 24px 32px 16px !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-buttons-wrapper { \n\n  display: flex !important; \n\n  flex-direction: row-reverse !important; \n\n  gap: 8px !important; \n\n} \n\n/* Buttons */ \n\n.walkme-survey-balloon .walkme-custom-balloon-normal-button { \n\n  width: auto !important; \n\n  min-width: 20px !important; \n\n  height: 26px !important; \n\n  margin: 0px !important; \n\n  padding: 0px 8px !important; \n\n  box-sizing: border-box !important; \n\n  background-color: var(--buttons_primary_default_fill_color) !important; \n\n  box-shadow: none !important; \n\n  border: var(--buttons_primary_default_border_width) solid var(--buttons_primary_default_border_color) !important; \n\n  border-radius: var(--buttons_primary_default_border_radius) !important; \n\norder: 0 !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-normal-button:hover { \n\nbackground-color: var(--buttons_primary_hover_fill_color) !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-normal-button:active { \n\nbackground-color: var(--buttons_primary_clicked_fill_color) !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-weak-button { \n\n  width: auto !important; \n\n  min-width: 20px !important; \n\n  height: 26px !important; \n\n  margin: 0px !important; \n\n  padding: 0px 8px !important; \n\n  box-sizing: border-box !important; \n\n  background-color: var(--buttons_secondary_default_fill_color) !important; \n\n  box-shadow: none !important; \n\n  border: var(--buttons_secondary_default_border_width) solid var(--buttons_secondary_default_border_color) !important; \n\n  border-radius: var(--buttons_secondary_default_border_radius) !important; \n\norder: 1 !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-weak-button:hover { \n\nbackground-color: var(--buttons_secondary_hover_fill_color) !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-weak-button:active { \n\nbackground-color: var(--buttons_secondary_clicked_fill_color) !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-normal-button .walkme-custom-balloon-button-text { \n\n  padding: 0px !important; \n\n  font-family: var(--fonts_primary_font) !important; \n\n  font-size: var(--typography_button_text_font_size) !important; \n\n  font-weight: 700 !important; \n\n  font-style: var(--typography_button_text_font_style) !important; \n\n  color: var(--buttons_primary_default_text_color) !important; \n\n  -webkit-font-smoothing: antialiased !important; \n\n} \n\n.walkme-survey-balloon .walkme-custom-balloon-weak-button .walkme-custom-balloon-button-text { \n\n  padding: 0px !important; \n\n  font-family: var(--fonts_primary_font) !important; \n\n  font-size: var(--typography_button_text_font_size) !important; \n\n  font-weight: 600 !important; \n\n  font-style: var(--typography_button_text_font_style) !important; \n\n  color: var(--buttons_secondary_default_text_color) !important; \n\n} \n\n/* Custom Survey Styles UX.LG -- END */ ","CustomHTML":[],"DebuggerSettings":{"IsInPlay":"1","IsInPreview":"1","IsInPublish":"1"},"DefaultBalloonVisualDes